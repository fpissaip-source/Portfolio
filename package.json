{
  "name": "issa-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:styles": "node scripts/sync-styles.mjs",
    "predev": "npm run sync:styles",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "npm run sync:styles",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gsap/react": "^2.1.1",
    "gsap": "^3.12.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-fast-marquee": "^1.6.5",
    "react-icons": "^5.3.0",
    "three": "^0.168.0",
    "three-stdlib": "^2.33.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.168.0",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
